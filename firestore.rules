rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자는 오직 자기 자신의 문서(users/{uid})와 그 하위 답변만 읽고 쓸 수 있어요.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /answers/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
